# DocMind AI文档问答系统 - 环境变量模板
# 复制为 .env 文件并填写实际值

# 服务端端口
PORT=3458

# DeepSeek API密钥
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API地址（可选，默认使用官方地址）
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# 上传文件大小限制（MB）
MAX_FILE_SIZE=10

# 文本切片大小（字符数）
CHUNK_SIZE=500

# 切片重叠大小（字符数）
CHUNK_OVERLAP=100
